# === LLM Provider 설정 ===
# 개체/관계 추출에 사용할 기본 provider. openai | ollama | anthropic 중 선택
LLM_PROVIDER=ollama

# 기본 provider 호출이 실패했을 때 순서대로 시도할 대체 provider (쉼표 구분, 비워두면 재시도 없음)
LLM_FALLBACK_PROVIDERS=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Ollama (로컬) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_BASE_URL=https://api.anthropic.com

# === Neo4j 내보내기 (선택) ===
# docker-compose.yml로 이 프로젝트 전용 Neo4j를 띄운다(호스트의 다른 Neo4j와
# 포트가 겹치지 않도록 7688/7475로 매핑). 비밀번호는 8자 이상으로 직접 설정한다.
#   docker compose up -d
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=
